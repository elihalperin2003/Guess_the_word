import random

words = [
    "tea",
    "pie",
    "egg",
    "milk",
    "rice",
    "soup",
    "cake",
    "fish",
    "meat",
    "beer",
    "pizza",
    "pasta",
    "bread",
    "apple",
    "juice",
    "steak",
    "salad",
    "water",
    "mango",
    "burger",
    "coffee",
    "cheese",
    "banana",
    "cookie",
    "yogurt",
    "potato",
    "butter",
    "chicken",
    "pancake",
    "popcorn",
    "avocado",
    "lasagna",
    "lemonade",
    "sandwich",
    "chocolate",
]


class CurrentRound:
    """Represents a single round of a word-guessing game."""

    def __init__(self):
        """Initialize a new round with a random word and default game state."""
        self.correct_word = random.choice(words)
        self.guess_word = "_" * len(self.correct_word)
        self.garbage = []
        self.attempts = 8

    def handle_wrong_guess(self, guess_letter):
        """Update the game state for an incorrect letter guess."""
        self.garbage.append(guess_letter)
        self.attempts -= 1

    def handle_correct_guess(self, guess_letter, indexes):
        """Reveal the correctly guessed letter at the specified positions."""
        list_guess_letters = list(self.guess_word)
        for ind in indexes:
            list_guess_letters[ind] = guess_letter
        self.guess_word = "".join(list_guess_letters)


def main():
    game_active = True
    while game_active:
        game = CurrentRound()
        while game.correct_word != game.guess_word and game.attempts != 0:
            print_details(game)
            guess_letter = input_letter(game.garbage, game.guess_word)
            indexes = check_letter(game.correct_word, guess_letter)
            if indexes:
                game.handle_correct_guess(guess_letter, indexes)
            else:
                game.handle_wrong_guess(guess_letter)
        if game.correct_word == game.guess_word:
            print(f"\nYou did it!\nThe word is \033[34m{game.correct_word}\033[0m")
        elif game.attempts == 0:
            print(
                f"\nGame over!\nThe correct word is \033[34m{game.correct_word}\033[0m"
            )
        exit_game = input(
            "To play another game, press Enter. to exit, press any other key:\n "
        )
        if exit_game:
            game_active = False


def print_details(game):
    print()
    print("===================")
    print()
    print("Guess the word:")
    print(f"\033[34m{game.guess_word}\033[0m")
    print(f"Garbage: {" - ".join(game.garbage)}")
    print(f"Attempts left: {game.attempts}")
    print()


def input_letter(garbage: list, guess_word: str):
    """Prompts for a single English letter, repeating until valid. Returns the input as a lowercase string."""
    right_input = False
    while not right_input:
        letter = input("enter letter: ")
        letter = letter.lower()
        if (
            not "a" <= letter <= "z"
            or len(letter) != 1
            or letter in garbage + list(guess_word)
        ):
            print("Incorrect input, please type again")
            continue
        else:
            right_input = True
    return letter


def check_letter(correct_word, guess_letter):
    """Returns the letter's index(es) if it exists in the word, otherwise "not found"."""
    indexes = []
    for index, letter in enumerate(correct_word):
        if letter == guess_letter:
            indexes.append(index)
    return indexes


if __name__ == "__main__":
    main()
