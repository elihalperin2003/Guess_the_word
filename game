import random


class Current_round:
    def __init__(self):
        self.correct_word = get_random_word()
        self.guess_word = "_" * len(self.correct_word)
        self.garbage = []
        self.attempts = 8

    def handle_wrong_guess(self, guess_letter):
        self.garbage.append(guess_letter)
        self.attempts -= 1

    def handle_correct_guess(self, guess_letter, indexes):
        list_guess_letters = list(self.guess_word)
        for ind in indexes:
            list_guess_letters[ind] = guess_letter
        self.guess_word = "".join(list_guess_letters)

    def print_detales(self):
        print()
        print("===================")
        print()
        print("Guess the word:")
        print(f"\033[34m{self.guess_word}\033[0m")
        print(f"Garbage: {" - ".join(self.garbage)}")
        print(f"Attempts left: {self.attempts}")
        print()


def main():
    game_active = True
    while game_active:
        game = Current_round()
        while game.correct_word != game.guess_word and game.attempts != 0:
            game.print_detales()
            guess_letter = input_letter(game.garbage)
            indexes = check_letter(game.correct_word, guess_letter)
            if indexes == "not found":
                game.handle_wrong_guess(guess_letter)
            else:
                game.handle_correct_guess(guess_letter, indexes)
        if game.correct_word == game.guess_word:
            print(f"\nYou did it!\nThe word is {game.correct_word}")
        elif game.attempts == 0:
            print(f"\nGame over!\nThe correct word is {game.correct_word}")
        exit_game = input(
            "To play another game, press Enter. to exit, press any other key:\n "
        )
        if exit_game:
            game_active = False


def get_random_word():
    words = [
        "dog",
        "sky",
        "cup",
        "pen",
        "red",
        "ball",
        "tree",
        "fast",
        "gold",
        "jump",
        "bread",
        "mouse",
        "beach",
        "clock",
        "smile",
        "winter",
        "rocket",
        "forest",
        "orange",
        "banana",
        "window",
        "teacher",
        "kitchen",
        "picture",
        "morning",
        "mountain",
        "birthday",
        "hospital",
        "elephant",
        "sandwich",
        "chocolate",
    ]
    return random.choice(words)


def input_letter(garbage):
    """Prompts for a single English letter, repeating until valid. Returns the input as a lowercase string."""
    right_input = False
    while not right_input:
        letter = input("enter letter: ")
        letter = letter.lower()
        if not "a" <= letter <= "z" or len(letter) != 1 or letter in garbage:
            print("Incorrect input, please type again")
            continue
        else:
            right_input = True
    return letter


def check_letter(correct_word, guess_letter):
    """Returns the letter's index(es) if it exists in the word, otherwise "not found"."""
    indexes = []
    for index, letter in enumerate(correct_word):
        if letter == guess_letter:
            indexes.append(index)
    if not indexes:
        return "not found"
    return indexes


main()
