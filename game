import random


class Current_round:
    def __init__(self):
        self.correct_word = get_random_word()
        self.guess_word = "_" * len(self.correct_word)
        self.garbage = []
        self.attempts = 8


def main():
    game_active = True
    while game_active:
        game = Current_round()
        while game.correct_word != game.guess_word or game.attempts != 0:
            print_detales(game.guess_word, game.garbage, game.attempts)
            guess_letter = input_letter()
            index = check_letter(game.correct_word, guess_letter)
            if index == "not found":
                handle_wrong_guess(game.garbage, guess_letter, game.attempts)
            else:
                handle_correct_guess(game.correct_word, guess_letter, index)
        if game.correct_word == game.guess_word:
            print(f"You did it!\nThe word is {game.correct_word}")
        elif game.attempts == 0:
            print(f"Game over!\nThe correct word is {game.correct_word}")
        exit_game = input(
            "To play another game, press Enter. to exit, press any other key"
        )
        if exit_game:
            game_active = False


def get_random_word():
    words = ["a", "bb", "ccc"]
    return words[random.randint(0, len(words) - 1)]


def print_detales(guess_word, garbage: list, attempts):
    print()
    print("Guess the word:")
    print(guess_word)
    print(f"Garbage: {[letter for letter in garbage]}")
    print(f"Attempts left: {attempts}")


def input_letter():
    """Prompts for a single English letter, repeating until valid. Returns the input as a lowercase string."""
    right_input = False
    while not right_input:
        letter = input("enter letter: ")
        letter = letter.lower()
        if not "a" <= letter <= "z" or len(letter) != 1:
            print("Incorrect input, please type again")
            continue
        else:
            right_input = True
    return letter


def check_letter(correct_word, guess_letter):
    """Returns the letter's index if it exists in the word, otherwise False."""
    for index, letter in enumerate(correct_word):
        if letter == guess_letter:
            return index
    return "not found"


def handle_wrong_guess(garbage: list, guess_letter, attempts):
    garbage.append(guess_letter)
    attempts -= 1


def handle_correct_guess(correct_word, guess_letter, index):
    correct_word[index] = guess_letter
